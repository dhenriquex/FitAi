generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Goal {
  perder_gordura
  ganhar_massa_muscular
  definir_corpo
  aumentar_forca
  melhorar_condicionamento
  melhorar_saude
  manter_peso
  ganhar_resistencia
  melhorar_mobilidade
}

enum ActivityLevel {
  sedentarioj
  pouco_ativo
  moderadamente_ativo
  ativo
  muito_ativo
  atleta
}

enum Experience {
  iniciante
  intermediario
  avancado
  especialista
}

enum Injury {
  nenhuma
  joelho
  ombro
  coluna
  lombar
  cervical
  quadril
  cotovelo
  punho
  tornozelo
  tendinite
  lesao_muscular
  hernia_de_disco
  outra
}

enum Gender {
  male
  female
  nonBinary
  nonInformation
}

model User {
  id           Int           @id @default(autoincrement())
  firebaseUid  String        @unique
  name         String
  email        String        @unique
  measurements Measurement[]
  profile      Profile?
  workoutPlans WorkoutPlan[]
  sessions     Session[]
  accounts     Account[]

  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
}

model Profile {
  id Int @id @default(autoincrement())

  birthDate DateTime

  gender Gender

  height Float
  weight Float

  targetWeight Float?

  goal          Goal
  activityLevel ActivityLevel
  experience    Experience

  injuries String?

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])
}

model WorkoutPlan {
  id          String       @id @default(uuid())
  name        String
  userId      Int
  isActive    Boolean      @default(true)
  updatedAt   DateTime     @updatedAt @db.Timestamptz(6)
  createdAt   DateTime     @default(now()) @db.Timestamptz(6)
  coverImage  String?
  workoutDays WorkoutDay[]
  user        User         @relation(fields: [userId], references: [id])
}

model WorkoutDay {
  id                     String           @id @default(uuid())
  name                   String
  workoutPlanId          String
  isRest                 Boolean          @default(false)
  weekDay                WeekDay
  updatedAt              DateTime         @updatedAt @db.Timestamptz(6)
  createdAt              DateTime         @default(now()) @db.Timestamptz(6)
  estimativeTimeInSecond Int
  exercises              Exercise[]
  workoutPlan            WorkoutPlan      @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  session                WorkoutSession[]
}

model Exercise {
  id                     String     @id @default(uuid())
  name                   String
  order                  Int
  workoutDayId           String
  sets                   Int
  reps                   Int
  restTime               Int
  technique              String?
  exerciseLibraryItemId  String?
  createdAt              DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime   @updatedAt @db.Timestamptz(6)
  workoutDay             WorkoutDay            @relation(fields: [workoutDayId], references: [id])
  exerciseLibraryItem    ExerciseLibraryItem?  @relation(fields: [exerciseLibraryItemId], references: [id])
}

model ExerciseLibraryItem {
  id               String     @id
  name             String
  bodyPart         String
  equipment        String
  target           String
  gifUrl           String?
  secondaryMuscles String[]
  instructions     String[]
  exercises        Exercise[]

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([bodyPart])
  @@index([target])
  @@index([equipment])
}

model Session {
  id        String   @id
  expiresAt DateTime @db.Timestamptz(6)
  token     String   @unique
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  ipAddress String?
  userAgent String?
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                Int
  providerType          String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @db.Timestamptz(6)
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @db.Timestamptz(6)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model WorkoutSession {
  id           String     @id @default(uuid())
  workoutDayId String
  startedAt    DateTime   @db.Timestamptz(6)
  completed    DateTime?  @db.Timestamptz(6)
  createdAt    DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @db.Timestamptz(6)
  workoutDay   WorkoutDay @relation(fields: [workoutDayId], references: [id])
}

enum WeekDay {
  Monday
  Tuesday
  Wednesday
  Thursday
  Friday
  Saturday
  Sunday
}

model Measurement {
  id        Int      @id @default(autoincrement())
  userId    Int
  chest     Float
  shoulder  Float
  neck      Float
  arm       Float
  forearm   Float
  waist     Float
  hip       Float
  calf      Float
  abdomen   Float
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id])
}

